# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.tar.gz

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local
.claude/settings.local.json
.claude/agent-memory-local/

# Brain inbox (transient)
_brain/inbox/*
!_brain/inbox/.gitkeep

# Playwright artifacts (test-results = traces on failure; report = HTML output)
/test-results/
/playwright-report/
/playwright/.cache/

# Lighthouse CI artifacts
/.lighthouseci/

# Supabase CLI local state (project link metadata, pooler URLs — may include secrets)
supabase/.temp/
supabase/.branches/
.claude/agent-memory/
.env.local*
