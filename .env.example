# Oak Fantasy — environment variables template
# Copy to .env.local (gitignored) and fill with real values. NEVER commit .env.local.

# ── Supabase (public — safe to expose to the browser) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Supabase service role (SERVER ONLY — never NEXT_PUBLIC_, never client) ───
# Used by 'use server' actions / route handlers (guest orders, stock writes).
# Bypasses Row Level Security — keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Reserved for later Etape (3–5) — add when those features land ────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RESEND_API_KEY=
# SAMEDAY_API_KEY=
# SMARTBILL_API_KEY=
# NETOPIA_API_KEY=
